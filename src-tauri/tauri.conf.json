{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "上传测试文件生成器",
  "version": "0.1.5",
  "identifier": "com.terre.upload-test-file-generator",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "上传测试文件生成器",
        "width": 1120,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": false
    },
    "category": "DeveloperTool"
  }
}
